{
  "addr": "127.0.0.1:8080",
  "authToken": "dev-token-change-me",
  "workspaceRoots": [
    {
      "id": "sandbox",
      "name": "Air Code Sandbox",
      "root": "/Users/m1ns2o128/Documents/project/air-code/aircode-sandbox",
      "ignore": [".git", ".aircode", ".build", "node_modules", "target", "dist"],
      "commandPolicy": {
        "enabled": true,
        "allowedCommands": ["pwd", "ls", "git", "go", "swift", "cat"],
        "timeoutSeconds": 30,
        "terminalEnabled": true,
        "allowedShells": ["/bin/zsh", "/bin/bash", "/bin/sh"],
        "maxSessions": 2,
        "idleTimeoutSeconds": 900
      }
    }
  ],
  "projects": [
    {
      "id": "sample-app",
      "name": "Sample App",
      "root": "/Users/m1ns2o128/Documents/project/air-code/aircode-sandbox/sample-app",
      "ignore": [".git", ".aircode", ".build", "node_modules", "target", "dist"],
      "commandPolicy": {
        "enabled": true,
        "allowedCommands": ["pwd", "ls", "git", "go", "swift", "cat"],
        "timeoutSeconds": 30,
        "terminalEnabled": true,
        "allowedShells": ["/bin/zsh", "/bin/bash", "/bin/sh"],
        "maxSessions": 2,
        "idleTimeoutSeconds": 900
      }
    }
  ],
  "agents": {
    "codex": {
      "enabled": true,
      "command": "codex",
      "args": [
        "-a",
        "never",
        "exec",
        "--json",
        "--color",
        "never",
        "-s",
        "workspace-write",
        "--skip-git-repo-check",
        "{{prompt}}"
      ],
      "timeoutSeconds": 600,
      "outputFormat": "codex-json",
      "installStatus": "configured"
    },
    "claude": {
      "enabled": false,
      "command": "",
      "args": [],
      "timeoutSeconds": 600,
      "installStatus": "missing"
    },
    "opencode": {
      "enabled": false,
      "command": "",
      "args": [],
      "timeoutSeconds": 600,
      "installStatus": "missing"
    },
    "hermes": {
      "enabled": false,
      "command": "hermes",
      "args": ["chat", "--quiet", "-q", "{{prompt}}"],
      "timeoutSeconds": 600,
      "outputFormat": "final-text",
      "installStatus": "missing"
    }
  }
}
