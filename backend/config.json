{
  "addr": "127.0.0.1:8080",
  "authToken": "dev-token-change-me",
  "stateDir": "/Users/m1ns2o128/Documents/project/air-code/backend/.aircode-state",
  "workspaceRoots": [
    {
      "id": "sandbox",
      "name": "Air Code Sandbox",
      "root": "/Users/m1ns2o128/Documents/project/air-code/aircode-sandbox",
      "ignore": [
        ".git",
        ".aircode",
        ".build",
        "node_modules",
        "target",
        "dist"
      ],
      "commandPolicy": {
        "enabled": true,
        "allowedCommands": [
          "pwd",
          "ls",
          "git",
          "go",
          "swift",
          "cat"
        ],
        "timeoutSeconds": 30,
        "terminalEnabled": true,
        "allowedShells": [
          "/bin/zsh",
          "/bin/bash",
          "/bin/sh"
        ],
        "maxSessions": 2,
        "idleTimeoutSeconds": 900,
        "detachedTimeoutSeconds": 30
      }
    }
  ],
  "projects": [
    {
      "id": "sample-app",
      "name": "Sample App",
      "root": "/Users/m1ns2o128/Documents/project/air-code/aircode-sandbox/sample-app",
      "ignore": [
        ".git",
        ".aircode",
        ".build",
        "node_modules",
        "target",
        "dist"
      ],
      "commandPolicy": {
        "enabled": true,
        "allowedCommands": [
          "pwd",
          "ls",
          "git",
          "go",
          "swift",
          "cat"
        ],
        "timeoutSeconds": 30,
        "terminalEnabled": true,
        "allowedShells": [
          "/bin/zsh",
          "/bin/bash",
          "/bin/sh"
        ],
        "maxSessions": 2,
        "idleTimeoutSeconds": 900,
        "detachedTimeoutSeconds": 30
      }
    }
  ],
  "agents": {
    "claude": {
      "enabled": true,
      "command": "/opt/homebrew/bin/claude",
      "args": [
        "-p",
        "{{prompt}}"
      ],
      "timeoutSeconds": 600,
      "outputFormat": "final-text",
      "runtimeSteering": "stdin",
      "installStatus": "configured"
    },
    "codex": {
      "enabled": true,
      "command": "/opt/homebrew/bin/codex",
      "args": [
        "-a",
        "never",
        "exec",
        "--json",
        "--color",
        "never",
        "-s",
        "workspace-write",
        "--skip-git-repo-check",
        "{{prompt}}"
      ],
      "timeoutSeconds": 600,
      "outputFormat": "codex-json",
      "installStatus": "configured"
    },
    "hermes": {
      "enabled": true,
      "command": "/Users/m1ns2o128/.local/bin/hermes",
      "args": [
        "chat",
        "--quiet",
        "-q",
        "{{prompt}}"
      ],
      "timeoutSeconds": 600,
      "outputFormat": "final-text",
      "installStatus": "configured"
    },
    "opencode": {
      "enabled": false,
      "command": "",
      "args": [],
      "timeoutSeconds": 600,
      "outputFormat": "",
      "installStatus": "missing"
    }
  }
}
